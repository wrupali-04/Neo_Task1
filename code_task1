def task1(user, target):
    met = {}

    for i in range(len(user)):
        complement = target - user[i]

        if complement in met:
            return [met[complement], i]

        met[user[i]] = i

user = list(map(int, input("Enter array: ").split()))
target = int(input("Enter taret of choice: "))

result = task1(user, target)

print("indices", result)
